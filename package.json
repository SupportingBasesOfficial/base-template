{
  "name": "@supporting-bases/base-template",
  "version": "1.0.0",
  "description": "The definitive MEGA-TECH monorepo template. Engineered for absolute scale and resilience using Turborepo, Next.js 15, Tailwind v3, and Supabase.",
  "author": "SupportingBasesOficial",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "vitest",
    "test:run": "vitest run",
    "prepare": "husky",
    "clean": "rimraf **/node_modules **/.next **/dist .turbo",
    "sync-db:win": "powershell ./sync-db.ps1",
    "sync-db:unix": "chmod +x ./sync-db.sh && ./sync-db.sh"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.5",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.7.4",
    "rimraf": "^6.0.1",
    "turbo": "^2.9.10",
    "typescript": "5.9.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm eslint --max-warnings 0 --no-warn-ignored",
      "pnpm prettier --write"
    ],
    "*.{json,md,css}": [
      "pnpm prettier --write"
    ]
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
