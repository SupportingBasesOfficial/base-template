{
  "name": "@supporting-bases/base-template",
  "version": "1.0.0",
  "description": "The definitive MEGA-TECH monorepo template. Engineered for absolute scale and resilience using Turborepo, Next.js 15, Tailwind v3, and Supabase.",
  "author": "SupportingBasesOficial",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:ci": "CI=true playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "analyze": "ANALYZE=true pnpm build",
    "prepare": "husky",
    "clean": "rimraf **/node_modules **/.next **/dist .turbo",
    "sync-db": "node sync-db.mjs",
    "gen:page": "node scripts/gen-page.mjs",
    "gen:component": "node scripts/gen-component.mjs",
    "gen:api": "node scripts/gen-api.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm version-packages && pnpm publish -r"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@react-email/components": "^1.0.12",
    "@sentry/nextjs": "^10.63.0",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vercel/otel": "^2.1.3",
    "@vitest/ui": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "react-email": "^6.6.6",
    "rimraf": "^6.0.1",
    "storybook": "^8.6.18",
    "turbo": "^2.9.10",
    "typescript": "5.9.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm eslint --max-warnings 0 --no-warn-ignored",
      "pnpm prettier --write"
    ],
    "*.{json,md,css}": [
      "pnpm prettier --write"
    ]
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
