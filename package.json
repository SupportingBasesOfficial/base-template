{
  "name": "base-template",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "vitest",
    "test:run": "vitest run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.7.4",
    "turbo": "^2.9.10",
    "typescript": "5.9.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm eslint --max-warnings 0",
      "pnpm prettier --write"
    ],
    "*.{json,md,css}": [
      "pnpm prettier --write"
    ]
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
