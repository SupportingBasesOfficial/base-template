# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL para SEO (robots.ts, sitemap.ts)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase CLI — para sync-db e migrations cloud
# Encontre em: Supabase Dashboard > Project Settings > General > Reference ID
SUPABASE_PROJECT_REF=your-project-ref

# Sentry (opcional — deixa vazio para desabilitar)
# Server-side (server/edge configs):
SENTRY_DSN=
# Client-side (browser — deve ter prefixo NEXT_PUBLIC_):
NEXT_PUBLIC_SENTRY_DSN=

# Cron jobs (opcional — configure um secret aleatório)
CRON_SECRET=your-random-cron-secret

# Webhook Supabase (opcional — configure no Supabase Dashboard)
SUPABASE_WEBHOOK_SECRET=your-webhook-secret

# Feature flags (opcional — defaults em lib/feature-flags.ts)
# ENABLE_NEW_DASHBOARD=false
# ENABLE_EXPERIMENTAL_FEATURE=false

# React Compiler (opcional — experimental)
# ENABLE_REACT_COMPILER=true

# Partial Prerendering (opcional — experimental)
# ENABLE_PPR=true

# OpenTelemetry (opcional — configurado automaticamente na Vercel)
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=

# Variáveis server-side (adicione quando necessário)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
