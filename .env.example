# --- Variáveis de Ambiente do Next.js (apps/web) ---

# URL pública do projeto Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Chave anônima pública do Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Variáveis de Ambiente do Supabase (packages/supabase) ---

# Reference ID do projeto Supabase (Project Settings > API)
SUPABASE_PROJECT_REF=your-project-ref

# --- Opcional: Upstash Redis (rate limiting) ---

# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# --- Opcional: Sentry (error tracking) ---

# SENTRY_DSN=your-sentry-dsn
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# --- Opcional: Analytics ---

# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
